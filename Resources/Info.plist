<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.chrisno.click-to-min</string>
	<key>CFBundleName</key>
	<string>ClickToMin</string>
	<key>CFBundleExecutable</key>
	<string>ClickToMin</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<!--
	  LSUIElement + NSApp.setActivationPolicy(.accessory) are intentionally
	  redundant. LSUIElement is authoritative for .app launches (Gatekeeper
	  path); the activation-policy call covers `swift run` / unbundled
	  launches.
	-->
	<key>LSUIElement</key>
	<true/>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
  <key>NSAccessibilityUsageDescription</key>
  <string>ClickToMin needs Accessibility access to detect Dock clicks and minimize the focused window of the active app.</string>
  <key>CFBundleIconFile</key>
  <string>AppIcon</string>
</dict>
</plist>
